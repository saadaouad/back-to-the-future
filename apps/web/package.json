{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check-types": "tsc --noEmit",
    "test:unit": "vitest run --config ../../vitest.config.ts --project web-unit",
    "test:integration": "vitest run --config ../../vitest.config.ts --project web-integration"
  },
  "dependencies": {
    "@repo/schema-validation": "*",
    "@tanstack/react-query": "^5.85.5",
    "clsx": "^2.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.12",
    "typescript": "5.9.2",
    "vite": "^7.1.2"
  }
}
