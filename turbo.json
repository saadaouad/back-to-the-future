{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "envMode": "loose",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "format": {},
    "format:fix": {
      "cache": false
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "test:unit": {},
    "test:integration": {},
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
